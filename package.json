{
  "name": "justinthelaw",
  "version": "1.0.0",
  "description": "Justin Law's customizable personal website with an AI chatbot",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "serve out -l 3000",
    "lint": "eslint .",
    "test": "playwright test",
    "deploy": "npm run build && gh-pages -d out",
    "clean": "rm -rf out test-results playwright-report .next test-results.json node_modules",
    "flight-check": "npm run clean && npm run lint && npm run build && npm run test",
    "postinstall": "playwright install"
  },
  "dependencies": {
    "@deemlol/next-icons": "^0.2.1",
    "@huggingface/transformers": "^3.8.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gh-pages": "^6.3.0",
    "postcss": "^8",
    "serve": "^14.2.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5",
    "typescript-eslint": "^8.53.0"
  }
